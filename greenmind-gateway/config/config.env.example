BACKEND_BASE_URL=http://macmini.local:8000
DEVICE_API_KEY=replace_with_actual_api_key
LISTEN_ADDR=0.0.0.0:8081
QUEUE_DB_PATH=/var/lib/greenmind-gateway/queue.db
MAX_QUEUE_SIZE=100000
LOG_LEVEL=INFO

# Security & Mapping
ALLOW_UNAUTHENTICATED_ESP32=true
ESP32_KEYS_FILE=/etc/greenmind-gateway/esp32_keys.json
STATION_MAP_FILE=/etc/greenmind-gateway/station_map.json
