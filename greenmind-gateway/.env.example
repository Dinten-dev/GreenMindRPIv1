# GreenMind Gateway — Environment Variables
# Copy this file to .env on the Raspberry Pi.

CLOUD_API_URL=https://api.greenmind.xyz/api/v1
DB_PATH=/opt/greenmind/data/queue.db
SECRETS_PATH=/opt/greenmind/data/secrets.json
LOG_DIR=/opt/greenmind/data/logs
LOG_LEVEL=INFO
UPLOAD_INTERVAL=10
HEARTBEAT_INTERVAL=60
MAX_QUEUE_SIZE=100000
